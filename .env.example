# Environment variables for 3DPricey

# Database Configuration
DB_USER=3dpricey_user
DB_PASSWORD=secure_password_change_me
DATABASE_URL=postgresql://3dpricey_user:secure_password_change_me@postgres:5432/3dpricey

# JWT Authentication
JWT_SECRET=your_jwt_secret_key_here_change_me_min_32_characters
JWT_EXPIRY=7d
REFRESH_TOKEN_EXPIRY=30d

# Server Configuration
API_PORT=3001
NODE_ENV=production
FRONTEND_URL=http://localhost:8080

# Redis Cache
REDIS_URL=redis://redis:6379

# MinIO File Storage
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=3dpricey-files
MINIO_REGION=us-east-1
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_USE_SSL=false

# Frontend
VITE_API_URL=http://localhost:3001/api
