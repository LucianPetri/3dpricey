# Environment variables for deploy/docker-compose.deploy.yml

# Container naming / environment label
APP_ENV=dev

# Published image source
GHCR_OWNER=your_github_username_or_org
# Use a published GHCR tag from your releases or workflow output.
IMAGE_TAG=your_image_tag_here

# Database
DB_USER=3dpricey_user
DB_PASSWORD=secure_password_change_me

# Backend auth
# Generate with: openssl rand -base64 32
JWT_SECRET=replace_with_generated_secret

# MinIO
MINIO_ACCESS_KEY=minioadmin
# Change this for real deployments; the example value is not secure.
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=3dpricey-files

# Pangolin Newt
PANGOLIN_ENDPOINT=https://app.pangolin.net
NEWT_ID=your_newt_id_here
NEWT_SECRET=your_newt_secret_here
PANGOLIN_BLUEPRINT_FILE=/blueprints/3dpricey-dev.yml
